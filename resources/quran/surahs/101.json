{"number":101,"name":"سُورَةُ القَارِعَةِ","englishName":"Al-Qaari'a","englishTranslation":"The Calamity","revelationType":"Meccan","numberOfAyahs":11,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱلْقَارِعَةُ","translation":"The Striking Calamity -","juz":30,"page":600},{"number":2,"arabic":"مَا ٱلْقَارِعَةُ","translation":"What is the Striking Calamity?","juz":30,"page":600},{"number":3,"arabic":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ","translation":"And what can make you know what is the Striking Calamity?","juz":30,"page":600},{"number":4,"arabic":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ","translation":"It is the Day when people will be like moths, dispersed,","juz":30,"page":600},{"number":5,"arabic":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ","translation":"And the mountains will be like wool, fluffed up.","juz":30,"page":600},{"number":6,"arabic":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ","translation":"Then as for one whose scales are heavy [with good deeds],","juz":30,"page":600},{"number":7,"arabic":"فَهُوَ فِى عِيشَةٍۢ رَّاضِيَةٍۢ","translation":"He will be in a pleasant life.","juz":30,"page":600},{"number":8,"arabic":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ","translation":"But as for one whose scales are light,","juz":30,"page":600},{"number":9,"arabic":"فَأُمُّهُۥ هَاوِيَةٌۭ","translation":"His refuge will be an abyss.","juz":30,"page":600},{"number":10,"arabic":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ","translation":"And what can make you know what that is?","juz":30,"page":600},{"number":11,"arabic":"نَارٌ حَامِيَةٌۢ","translation":"It is a Fire, intensely hot.","juz":30,"page":600}]}
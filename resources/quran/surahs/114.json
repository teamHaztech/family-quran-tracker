{"number":114,"name":"سُورَةُ النَّاسِ","englishName":"An-Naas","englishTranslation":"Mankind","revelationType":"Meccan","numberOfAyahs":6,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ","translation":"Say, \"I seek refuge in the Lord of mankind,","juz":30,"page":604},{"number":2,"arabic":"مَلِكِ ٱلنَّاسِ","translation":"The Sovereign of mankind.","juz":30,"page":604},{"number":3,"arabic":"إِلَٰهِ ٱلنَّاسِ","translation":"The God of mankind,","juz":30,"page":604},{"number":4,"arabic":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ","translation":"From the evil of the retreating whisperer -","juz":30,"page":604},{"number":5,"arabic":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ","translation":"Who whispers [evil] into the breasts of mankind -","juz":30,"page":604},{"number":6,"arabic":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ","translation":"From among the jinn and mankind.\"","juz":30,"page":604}]}
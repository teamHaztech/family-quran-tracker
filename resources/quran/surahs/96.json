{"number":96,"name":"سُورَةُ العَلَقِ","englishName":"Al-Alaq","englishTranslation":"The Clot","revelationType":"Meccan","numberOfAyahs":19,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ","translation":"Recite in the name of your Lord who created -","juz":30,"page":597},{"number":2,"arabic":"خَلَقَ ٱلْإِنسَٰنَ مِنْ عَلَقٍ","translation":"Created man from a clinging substance.","juz":30,"page":597},{"number":3,"arabic":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ","translation":"Recite, and your Lord is the most Generous -","juz":30,"page":597},{"number":4,"arabic":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ","translation":"Who taught by the pen -","juz":30,"page":597},{"number":5,"arabic":"عَلَّمَ ٱلْإِنسَٰنَ مَا لَمْ يَعْلَمْ","translation":"Taught man that which he knew not.","juz":30,"page":597},{"number":6,"arabic":"كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ","translation":"No! [But] indeed, man transgresses","juz":30,"page":597},{"number":7,"arabic":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ","translation":"Because he sees himself self-sufficient.","juz":30,"page":597},{"number":8,"arabic":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ","translation":"Indeed, to your Lord is the return.","juz":30,"page":597},{"number":9,"arabic":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ","translation":"Have you seen the one who forbids","juz":30,"page":597},{"number":10,"arabic":"عَبْدًا إِذَا صَلَّىٰٓ","translation":"A servant when he prays?","juz":30,"page":597},{"number":11,"arabic":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ","translation":"Have you seen if he is upon guidance","juz":30,"page":597},{"number":12,"arabic":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ","translation":"Or enjoins righteousness?","juz":30,"page":597},{"number":13,"arabic":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","translation":"Have you seen if he denies and turns away -","juz":30,"page":597},{"number":14,"arabic":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ","translation":"Does he not know that Allah sees?","juz":30,"page":597},{"number":15,"arabic":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ","translation":"No! If he does not desist, We will surely drag him by the forelock -","juz":30,"page":597},{"number":16,"arabic":"نَاصِيَةٍۢ كَٰذِبَةٍ خَاطِئَةٍۢ","translation":"A lying, sinning forelock.","juz":30,"page":597},{"number":17,"arabic":"فَلْيَدْعُ نَادِيَهُۥ","translation":"Then let him call his associates;","juz":30,"page":597},{"number":18,"arabic":"سَنَدْعُ ٱلزَّبَانِيَةَ","translation":"We will call the angels of Hell.","juz":30,"page":597},{"number":19,"arabic":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","translation":"No! Do not obey him. But prostrate and draw near [to Allah].","juz":30,"page":597}]}
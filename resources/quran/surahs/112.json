{"number":112,"name":"سُورَةُ الإِخۡلَاصِ","englishName":"Al-Ikhlaas","englishTranslation":"Sincerity","revelationType":"Meccan","numberOfAyahs":4,"ayahs":[{"number":1,"arabic":"بِسْمِ ٱللَّهِ ٱلرَّحْمَٰنِ ٱلرَّحِيمِ قُلْ هُوَ ٱللَّهُ أَحَدٌ","translation":"Say, \"He is Allah, [who is] One,","juz":30,"page":604},{"number":2,"arabic":"ٱللَّهُ ٱلصَّمَدُ","translation":"Allah, the Eternal Refuge.","juz":30,"page":604},{"number":3,"arabic":"لَمْ يَلِدْ وَلَمْ يُولَدْ","translation":"He neither begets nor is born,","juz":30,"page":604},{"number":4,"arabic":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ","translation":"Nor is there to Him any equivalent.\"","juz":30,"page":604}]}